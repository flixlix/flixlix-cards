{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "dependsOn": ["^build"]
    },
    "test": {
      "cache": true,
      "outputs": ["coverage/**"],
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$", 
        "$TURBO_ROOT$/packages/testing/vitest-base.js"
      ]
    },
    "precommit": {
      "cache": false,
      "dependsOn": ["^test", "^lint", "^format:check"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": false
    }
  }
}
