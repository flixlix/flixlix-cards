{
  "name": "energy-flow-card-plus",
  "private": true,
  "version": "0.2.0-beta.1",
  "type": "module",
  "description": "A power flow card for Home Assistant",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "dashboard",
    "custom-cards"
  ],
  "main": "./dist/energy-flow-card-plus.js",
  "exports": {
    ".": "./dist/energy-flow-card-plus.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flixlix/energy-flow-card-plus.git"
  },
  "author": "flixlix",
  "bugs": {
    "url": "https://github.com/flixlix/energy-flow-card-plus/issues"
  },
  "homepage": "https://github.com/flixlix/energy-flow-card-plus#readme",
  "scripts": {
    "build": "pnpm dlx rollup -c",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "release": "pnpm build && pnpm changeset tag",
    "clean": "rimraf dist node_modules",
    "start": "rollup -wc",
    "dev": "rollup -c --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write . --ignore-path ../../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../../.prettierignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "precommit": "pnpm typecheck && pnpm format:check && pnpm test && pnpm lint",
    "start:hass": "docker run --rm -p8123:8123 -v ./.hass_dev:/config homeassistant/home-assistant:beta"
  },
  "dependencies": {
    "@flixlix-cards/shared": "workspace:*",
    "@mdi/js": "^7.4.47",
    "custom-card-helpers": "^1.9.0",
    "home-assistant-js-websocket": "^8.2.0",
    "lit": "^2.8.0",
    "lit-element": "^2.5.1",
    "lit-html": "^2.8.0",
    "memoize-one": "^6.0.0",
    "sortable": "^2.0.0",
    "sortablejs": "^1.15.7",
    "superstruct": "^1.0.4",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@flixlix-cards/bundler": "workspace:*",
    "@flixlix-cards/eslint-config": "workspace:*",
    "@flixlix-cards/prettier-config": "workspace:*",
    "@flixlix-cards/testing": "workspace:*",
    "@flixlix-cards/typescript-config": "workspace:*",
    "@jest/globals": "^29.7.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^20.19.37",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "conventional-changelog-conventionalcommits": "^4.6.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-wc": "^3.1.0",
    "jest": "^29.7.0",
    "prettier": "3.8.2",
    "prettier-plugin-embed": "^0.5.1",
    "rollup": "^4.60.1",
    "rollup-plugin-minify-html-literals": "^1.2.6",
    "rollup-plugin-serve": "^1.1.1",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0"
}
