{
  "name": "energy-flow-card-plus",
  "private": true,
  "version": "0.2.3",
  "type": "module",
  "description": "A power flow card for Home Assistant",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "dashboard",
    "custom-cards"
  ],
  "main": "./dist/energy-flow-card-plus.js",
  "exports": {
    ".": "./dist/energy-flow-card-plus.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flixlix/energy-flow-card-plus.git"
  },
  "author": "flixlix",
  "bugs": {
    "url": "https://github.com/flixlix/energy-flow-card-plus/issues"
  },
  "homepage": "https://github.com/flixlix/energy-flow-card-plus#readme",
  "scripts": {
    "build": "pnpm dlx rollup -c",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "release": "pnpm build && pnpm changeset tag",
    "clean": "rimraf dist node_modules",
    "start": "rollup -wc",
    "dev": "rollup -c --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write . --ignore-path ../../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../../.prettierignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "precommit": "pnpm typecheck && pnpm format:check && pnpm test && pnpm lint",
    "start:hass": "docker run --rm -p8123:8123 -v ./.hass_dev:/config homeassistant/home-assistant:beta"
  },
  "dependencies": {
    "@flixlix-cards/shared": "workspace:*",
    "@mdi/js": "catalog:packages",
    "custom-card-helpers": "catalog:packages",
    "home-assistant-js-websocket": "catalog:packages",
    "lit": "catalog:packages",
    "lit-element": "catalog:packages",
    "lit-html": "catalog:packages",
    "memoize-one": "catalog:packages",
    "superstruct": "catalog:packages"
  },
  "devDependencies": {
    "@babel/core": "catalog:packages",
    "@babel/preset-env": "catalog:packages",
    "@babel/preset-typescript": "catalog:packages",
    "@changesets/changelog-github": "catalog:packages",
    "@changesets/cli": "catalog:packages",
    "@flixlix-cards/bundler": "workspace:*",
    "@flixlix-cards/eslint-config": "workspace:*",
    "@flixlix-cards/prettier-config": "workspace:*",
    "@flixlix-cards/testing": "workspace:*",
    "@flixlix-cards/typescript-config": "workspace:*",
    "@jest/globals": "catalog:packages",
    "@rollup/plugin-babel": "catalog:packages",
    "@rollup/plugin-commonjs": "catalog:packages",
    "@rollup/plugin-json": "catalog:packages",
    "@rollup/plugin-node-resolve": "catalog:packages",
    "@rollup/plugin-terser": "catalog:packages",
    "@rollup/plugin-typescript": "catalog:packages",
    "@types/node": "catalog:",
    "@types/sortablejs": "catalog:packages",
    "@typescript-eslint/eslint-plugin": "catalog:packages",
    "@typescript-eslint/parser": "catalog:packages",
    "conventional-changelog-conventionalcommits": "catalog:packages",
    "eslint": "catalog:packages",
    "eslint-config-prettier": "catalog:packages",
    "eslint-plugin-lit": "catalog:packages",
    "eslint-plugin-wc": "catalog:packages",
    "jest": "catalog:packages",
    "prettier": "catalog:",
    "prettier-plugin-embed": "catalog:packages",
    "rollup": "catalog:packages",
    "rollup-plugin-minify-html-literals": "catalog:packages",
    "rollup-plugin-serve": "catalog:packages",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:packages"
  },
  "packageManager": "pnpm@10.33.0"
}
