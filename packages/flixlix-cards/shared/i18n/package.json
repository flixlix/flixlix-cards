{
  "name": "@flixlix-cards/i18n",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist node_modules .turbo",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write . --ignore-path ../../../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../../../.prettierignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "precommit": "pnpm typecheck && pnpm format:check && pnpm test && pnpm lint"
  },
  "devDependencies": {
    "@flixlix-cards/eslint-config": "workspace:*",
    "@flixlix-cards/prettier-config": "workspace:*",
    "@flixlix-cards/testing": "workspace:*",
    "@flixlix-cards/typescript-config": "workspace:*",
    "eslint": "^9.21.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0"
}
