{
  "extends": "@flixlix-cards/typescript-config/react-library.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@flixlix-cards/ui/*": ["./src/*"],
      "react": ["./node_modules/@types/react"]
    },
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
