{
  "name": "@energy-cards/cn",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist node_modules .turbo",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@energy-cards/eslint-config": "workspace:*",
    "@energy-cards/prettier-config": "workspace:*",
    "@energy-cards/typescript-config": "workspace:*",
    "eslint": "^9.21.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}
