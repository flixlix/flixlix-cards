{
  "name": "@flixlix-cards/cn",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist node_modules .turbo",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write . --ignore-path ../../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../../.prettierignore"
  },
  "dependencies": {
    "clsx": "catalog:packages",
    "tailwind-merge": "catalog:packages"
  },
  "devDependencies": {
    "@flixlix-cards/eslint-config": "workspace:*",
    "@flixlix-cards/prettier-config": "workspace:*",
    "@flixlix-cards/typescript-config": "workspace:*",
    "eslint": "catalog:packages",
    "tsup": "catalog:packages",
    "typescript": "catalog:"
  }
}
