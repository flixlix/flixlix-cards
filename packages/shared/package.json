{
  "name": "@flixlix-cards/shared",
  "version": "0.0.5",
  "private": true,
  "type": "module",
  "exports": {
    "./i18n": "./src/i18n/index.ts",
    "./style": "./src/style/index.ts",
    "./types": "./src/types/index.ts",
    "./components/*": "./src/components/*.ts",
    "./ha/*": "./src/ha/*.ts",
    "./states/*": "./src/states/*.ts",
    "./utils/*": "./src/utils/*.ts",
    "./const/*": "./src/const/*.ts",
    "./ui-editor/*": "./src/ui-editor/*.ts"
  },
  "peerDependencies": {
    "custom-card-helpers": "catalog:packages",
    "home-assistant-js-websocket": "catalog:packages",
    "lit": "catalog:packages"
  },
  "scripts": {
    "clean": "rimraf dist node_modules .turbo",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "precommit": "pnpm typecheck && pnpm format:check && pnpm test && pnpm lint"
  },
  "devDependencies": {
    "@flixlix-cards/eslint-config": "workspace:*",
    "@flixlix-cards/prettier-config": "workspace:*",
    "@flixlix-cards/testing": "workspace:*",
    "@flixlix-cards/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/sortablejs": "catalog:packages",
    "eslint": "catalog:packages",
    "tsup": "catalog:packages",
    "typescript": "catalog:",
    "vitest": "catalog:packages"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@mdi/js": "catalog:packages",
    "lit-element": "catalog:packages",
    "lit-html": "catalog:packages",
    "memoize-one": "catalog:packages",
    "sortable": "^2.0.0",
    "sortablejs": "^1.15.7",
    "superstruct": "catalog:packages",
    "tslib": "^2.8.1"
  }
}
